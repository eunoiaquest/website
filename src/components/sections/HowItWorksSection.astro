---
interface Props {
  t: {
    heading: string;
    subheading: string;
    steps: { title: string; description: string }[];
    note: string;
    integration: string;
  };
}

const { t } = Astro.props;
---

<section id="how-it-works" class="py-16 md:py-24 bg-background">
  <div class="container mx-auto px-4 md:px-6">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-quicksand-medium text-foreground sm:text-4xl" style="font-weight:500;">
        {t.heading}
      </h2>
      <p class="mt-4 text-lg text-muted-foreground max-w-3xl mx-auto">
        {t.subheading}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {t.steps.map((step, index) => (
        <div class="rounded-lg border border-border bg-card p-6 shadow-sm">
          <p class="text-sm font-quicksand-medium text-primary mb-2" style="font-weight:500;">Step {index + 1}</p>
          <h3 class="text-xl font-quicksand-medium text-foreground mb-2" style="font-weight:500;">{step.title}</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>

    <div class="mt-8 rounded-lg border border-primary/30 bg-primary/5 p-6">
      <p class="text-foreground font-quicksand-medium" style="font-weight:500;">{t.note}</p>
      <p class="mt-2 text-muted-foreground">{t.integration}</p>
    </div>
  </div>
</section>

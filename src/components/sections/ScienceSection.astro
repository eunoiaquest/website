---
interface Props {
  t: {
    heading: string;
    subheading: string;
    highlights: string[];
    paperTitle: string;
    paperVenue: string;
    paperLinkText: string;
    paperLink: string;
  };
}

const { t } = Astro.props;
---

<section id="science" class="py-16 md:py-24 bg-secondary">
  <div class="container mx-auto px-4 md:px-6">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-quicksand-medium text-foreground sm:text-4xl" style="font-weight:500;">
        {t.heading}
      </h2>
      <p class="mt-4 text-lg text-muted-foreground max-w-3xl mx-auto">
        {t.subheading}
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-stretch">
      <div class="rounded-lg border border-border bg-card p-6 md:p-8 shadow-sm">
        <h3 class="text-2xl font-quicksand-medium text-foreground mb-4" style="font-weight:500;">{t.paperTitle}</h3>
        <p class="text-muted-foreground mb-4">{t.paperVenue}</p>
        <a
          href={t.paperLink}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-md bg-primary px-5 py-2 text-sm font-medium text-primary-foreground shadow hover:bg-primary/90 transition-colors"
        >
          {t.paperLinkText}
        </a>
      </div>

      <div class="rounded-lg border border-border bg-card p-6 md:p-8 shadow-sm">
        <ul class="space-y-3 text-muted-foreground">
          {t.highlights.map((item) => (
            <li class="flex items-start gap-3">
              <span class="mt-1 h-2 w-2 rounded-full bg-primary"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

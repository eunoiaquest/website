---
interface Props {
  t: {
    heading: string;
    logos: { src: string }[];
  };
}

const { t } = Astro.props;
const slidingLogos = [...t.logos, ...t.logos];
---

<section id="featured-in" class="py-16 md:py-24 bg-secondary">
  <div class="container mx-auto px-4 md:px-6">
    <div class="text-center mb-10 md:mb-12">
      <h2 class="text-3xl font-quicksand-medium text-foreground sm:text-4xl" style="font-weight:500;">
        {t.heading}
      </h2>
    </div>

    <div class="relative overflow-hidden py-2">
      <div class="featured-track flex w-max items-center gap-8 md:gap-12">
        {slidingLogos.map((logo) => (
          <div class="flex items-center justify-center rounded-lg border border-border bg-card/70 p-8 md:p-10 min-h-[240px] min-w-[360px] md:min-w-[460px]">
          <img
            src={logo.src}
            alt=""
            class="max-h-36 md:max-h-44 w-auto max-w-full object-contain grayscale opacity-80 transition duration-300 hover:grayscale-0 hover:opacity-100"
            loading="lazy"
          />
        </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .featured-track {
    animation: featured-slide 24s linear infinite;
  }

  .featured-track:hover {
    animation-play-state: paused;
  }

  @keyframes featured-slide {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }
</style>

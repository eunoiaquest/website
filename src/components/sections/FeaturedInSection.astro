---
interface Props {
  t: {
    heading: string;
    logos: { src: string; alt: string }[];
  };
}

const { t } = Astro.props;
---

<section id="featured-in" class="py-16 md:py-24 bg-secondary">
  <div class="container mx-auto px-4 md:px-6">
    <div class="text-center mb-10 md:mb-12">
      <h2 class="text-3xl font-quicksand-medium text-foreground sm:text-4xl" style="font-weight:500;">
        {t.heading}
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 md:gap-12 items-center">
      {t.logos.map((logo) => (
        <div class="flex items-center justify-center rounded-lg border border-border bg-card/70 p-6 md:p-8 min-h-[180px]">
          <img
            src={logo.src}
            alt={logo.alt}
            class="max-h-24 md:max-h-28 w-auto max-w-full object-contain grayscale opacity-80"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>

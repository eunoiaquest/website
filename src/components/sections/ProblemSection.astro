---
interface Props {
  t: {
    heading: string;
    subheading: string;
    stats: { value: string; label: string }[];
    bottleneckTitle: string;
    bottleneckPoints: string[];
  };
}

const { t } = Astro.props;
---

<section id="problem" class="py-16 md:py-24 bg-secondary">
  <div class="container mx-auto px-4 md:px-6">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-quicksand-medium text-foreground sm:text-4xl" style="font-weight:500;">
        {t.heading}
      </h2>
      <p class="mt-4 text-lg text-muted-foreground max-w-3xl mx-auto">
        {t.subheading}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
      {t.stats.map((stat) => (
        <div class="rounded-lg border border-border bg-card p-6 text-center shadow-sm">
          <p class="text-4xl md:text-5xl font-quicksand-medium text-primary" style="font-weight:500;">{stat.value}</p>
          <p class="mt-2 text-sm md:text-base text-muted-foreground">{stat.label}</p>
        </div>
      ))}
    </div>

    <div class="rounded-lg border border-border bg-card p-6 md:p-8 shadow-sm">
      <h3 class="text-2xl font-quicksand-medium text-foreground mb-4" style="font-weight:500;">{t.bottleneckTitle}</h3>
      <ul class="space-y-3 text-muted-foreground">
        {t.bottleneckPoints.map((point) => (
          <li class="flex items-start gap-3">
            <span class="mt-1 h-2 w-2 rounded-full bg-primary"></span>
            <span>{point}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

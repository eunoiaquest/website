---
interface Props {
  t: {
    heading: string;
    body: string;
    foundingStoryTitle: string;
    foundingStoryBody: string;
    learnMore: string;
    imageAlt: string;
  };
}
const { t } = Astro.props;
---

<section id="about" class="py-16 md:py-24 bg-background">
  <div class="container mx-auto px-4 md:px-6">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Image Column -->
      <div class="relative aspect-square rounded-lg overflow-hidden shadow-md">
        <img
          src="https://picsum.photos/600/600"
          alt={t.imageAlt}
          class="w-full h-full object-cover transition-transform duration-300 hover:scale-105"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/10 to-transparent"></div>
      </div>

      <!-- Text Column -->
      <div class="space-y-6">
        <h2 class="text-3xl font-quicksand-medium text-foreground sm:text-4xl" style="font-weight:500;">
          {t.heading}
        </h2>
        <p class="text-lg text-muted-foreground leading-relaxed">
          {t.body}
        </p>
        <div class="rounded-lg border border-border bg-secondary/40 p-5">
          <h3 class="text-xl font-quicksand-medium text-foreground mb-2" style="font-weight:500;">
            {t.foundingStoryTitle}
          </h3>
          <p class="text-base text-muted-foreground leading-relaxed">
            {t.foundingStoryBody}
          </p>
        </div>
        <a href="#about" class="text-primary hover:underline transition-colors inline-block">
          {t.learnMore}
        </a>
      </div>
    </div>
  </div>
</section>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { translations } from '../../i18n/translations';

const t = translations.de;
---

<BaseLayout lang="de" title={`${t.privacy.title} — eunoia Quest`} description={t.privacy.description}>
  <section class="py-16 md:py-24 bg-background">
    <div class="container mx-auto px-4 md:px-6 max-w-3xl">
      <h1 class="text-3xl font-quicksand-medium text-foreground sm:text-4xl mb-2" style="font-weight:500;">
        {t.privacy.title}
      </h1>
      <p class="text-sm text-muted-foreground mb-10">{t.privacy.lastUpdated}</p>

      <div class="space-y-8">
        {t.privacy.sections.map((section) => (
          <section>
            <h2 class="text-xl font-quicksand-medium text-foreground mb-3" style="font-weight:500;">
              {section.heading}
            </h2>
            <p class="text-muted-foreground leading-relaxed whitespace-pre-line">{section.body}</p>
          </section>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

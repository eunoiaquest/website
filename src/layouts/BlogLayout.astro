---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { translations, type Lang } from '../i18n/translations';

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const t = translations[lang];
const {
  title = t.blog.title,
  description = t.blog.description,
} = Astro.props;

// Rewrite anchor-only nav links to absolute paths so they navigate back to the landing page
const blogNavLinks = t.header.nav.map((link) => ({
  ...link,
  href: link.href.startsWith('#') ? `/${link.href}` : link.href,
}));
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-YG64ENNJTY"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-YG64ENNJTY');
    </script>

    <!-- Google Fonts: Quicksand -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Quicksand:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen bg-background font-sans antialiased">
    <Header navLinks={blogNavLinks} langSwitcher={t.header.langSwitcher} menuOpenLabel={t.header.menuOpenLabel} menuCloseLabel={t.header.menuCloseLabel} />
    <main>
      <slot />
    </main>
    <Footer allRightsReserved={t.footer.allRightsReserved} address={t.footer.address} />
  </body>
</html>

---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AnalyticsConsent from '../components/AnalyticsConsent.astro';
import CookieConsent from '../components/CookieConsent.astro';
import '../styles/global.css';
import { translations, type Lang } from '../i18n/translations';
import { resolveHomeHref, resolveNavLinks } from '../lib/nav';

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const t = translations[lang];
const {
  title = t.blog.title,
  description = t.blog.description,
} = Astro.props;

const navLinks = resolveNavLinks(t.header.nav, lang, false);
const homeHref = resolveHomeHref(lang, false);
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <AnalyticsConsent />

    <!-- Google Fonts: Quicksand -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Quicksand:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen bg-background font-sans antialiased flex flex-col">
    <Header
      navLinks={navLinks}
      homeHref={homeHref}
      menuOpenLabel={t.header.menuOpenLabel}
      menuCloseLabel={t.header.menuCloseLabel}
    />
    <main class="flex-1">
      <slot />
    </main>
    <Footer
      allRightsReserved={t.footer.allRightsReserved}
      address={t.footer.address}
      privacyLabel={t.footer.privacy}
      privacyHref={t.footer.privacyHref}
      cookieSettingsLabel={t.footer.cookieSettings}
    />
    <CookieConsent t={t.cookie} privacyHref={t.footer.privacyHref} />
  </body>
</html>
